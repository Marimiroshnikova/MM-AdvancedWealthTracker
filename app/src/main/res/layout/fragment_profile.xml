<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/pastel_bg"
    android:padding="24dp">

    <TextView
        android:id="@+id/mm_va_tv_profile_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/profile_title"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/text_dark"
        android:fontFamily="serif"
        android:letterSpacing="0.02"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="40dp"/>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/mm_va_card_avatar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/card_background"
        android:padding="28dp"
        app:layout_constraintTop_toBottomOf="@id/mm_va_tv_profile_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp">

        <TextView
            android:id="@+id/mm_va_tv_avatar"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:text="@string/profile_avatar"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/text_dark"
            android:gravity="center"
            android:background="@drawable/mm_va_profile_avatar_bg"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <TextView
            android:id="@+id/mm_va_tv_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/profile_name"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_dark"
            app:layout_constraintTop_toTopOf="@id/mm_va_tv_avatar"
            app:layout_constraintStart_toEndOf="@id/mm_va_tv_avatar"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginStart="16dp"/>

        <TextView
            android:id="@+id/mm_va_tv_dob"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/profile_dob"
            android:textSize="13sp"
            android:textColor="@color/text_medium"
            app:layout_constraintTop_toBottomOf="@id/mm_va_tv_name"
            app:layout_constraintStart_toEndOf="@id/mm_va_tv_avatar"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginStart="16dp"
            android:layout_marginTop="4dp"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/mm_va_card_formula"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/card_background"
        android:padding="24dp"
        app:layout_constraintTop_toBottomOf="@id/mm_va_card_avatar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp">

        <TextView
            android:id="@+id/mm_va_tv_k_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/label_coefficient"
            android:textSize="12sp"
            android:textColor="@color/text_medium"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/mm_va_tv_k_value"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/k_value"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="@color/text_dark"
            app:layout_constraintTop_toBottomOf="@id/mm_va_tv_k_label"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="8dp"/>

        <TextView
            android:id="@+id/mm_va_tv_formula"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/k_formula"
            android:textSize="14sp"
            android:textColor="@color/text_medium"
            app:layout_constraintTop_toBottomOf="@id/mm_va_tv_k_value"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="4dp"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>