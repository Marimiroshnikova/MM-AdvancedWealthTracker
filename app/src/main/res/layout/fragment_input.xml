<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/pastel_bg">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/mm_va_sv_input"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

    <TextView
        android:id="@+id/mm_va_tv_input_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/input_title"
        android:textSize="31sp"
        android:textStyle="bold"
        android:textColor="@color/text_dark"
        android:fontFamily="serif"
        android:letterSpacing="0.02"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="40dp"/>

    <TextView
        android:id="@+id/mm_va_tv_input_subtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/input_subtitle"
        android:textSize="14sp"
        android:textColor="@color/text_medium"
        app:layout_constraintTop_toBottomOf="@id/mm_va_tv_input_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="4dp"/>

    <TextView
        android:id="@+id/mm_va_tv_k_chip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/k_chip_fallback"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="@color/text_dark"
        android:background="@drawable/mm_va_chip_lavender"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toBottomOf="@id/mm_va_tv_input_subtitle"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="14dp"/>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/mm_va_card_income"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/edittext_background"
        android:padding="20dp"
        app:layout_constraintTop_toBottomOf="@id/mm_va_tv_k_chip"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp">

        <TextView
            android:id="@+id/mm_va_label_income"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/label_monthly_income"
            android:textSize="12sp"
            android:textColor="@color/text_medium"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <EditText
            android:id="@+id/mm_va_et_income"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:hint="@string/hint_income"
            android:inputType="numberDecimal"
            android:background="@drawable/edittext_background"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textSize="16sp"
            android:textColor="@color/text_dark"
            android:textColorHint="@color/text_medium"
            app:layout_constraintTop_toBottomOf="@id/mm_va_label_income"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="8dp"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/mm_va_card_expenses"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/edittext_background"
        android:padding="20dp"
        app:layout_constraintTop_toBottomOf="@id/mm_va_card_income"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp">

        <TextView
            android:id="@+id/mm_va_label_expenses"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/label_monthly_expenses"
            android:textSize="12sp"
            android:textColor="@color/text_medium"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <EditText
            android:id="@+id/mm_va_et_expenses"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:hint="@string/hint_expenses"
            android:inputType="numberDecimal"
            android:background="@drawable/edittext_background"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textSize="16sp"
            android:textColor="@color/text_dark"
            android:textColorHint="@color/text_medium"
            app:layout_constraintTop_toBottomOf="@id/mm_va_label_expenses"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="8dp"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

        <Button
            android:id="@+id/mm_va_btn_save"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:text="@string/btn_calculate"
            android:textSize="16sp"
            android:textColor="@color/text_dark"
            android:textStyle="bold"
            android:background="@drawable/button_background"
            android:stateListAnimator="@null"
            app:layout_constraintTop_toBottomOf="@id/mm_va_card_expenses"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="24dp"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>